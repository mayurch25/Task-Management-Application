<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  
  <body>
    <div class="main w-full bg-zinc-900 min-h-screen">
      <div class="form p-10 text-white">
        <form action="/create" method="post">
          <input
          type="text"
          class="block px-5 py-2 bg-zinc-800 w-full rounded-md outline-none"
          placeholder="Enter file name here"
          name="title"
          id="title"
          />
          <textarea
          name="details"
          id="details"
          placeholder="Enter Content"
          class="block px-5 py-2 bg-zinc-800 w-full rounded-md resize-none outline-none"
          ></textarea>
          <input
          class="mt-2 bg-blue-600 px-5 py-2 rounded-md"
          type="submit"
          value="Create File"
          id="submit"
          disabled
          />
        </form>
      </div>
      <div class="tasks p-10 flex gap-3 flex-wrap">
        <% if(files.length > 0) { %>
          <% files.forEach( function(val) { %>
            <div class="min-w-72 bg-zinc-800 px-3 py-4 rounded-md">
              <h1 class="text-white text-3xl tracking-tighter">
                <%= val %>
              </h1>
              <div class="mt-2 flex justify-between item-center">
                <a class="text-blue-500 inline-block" href="/file/<%= val %>">Read more</a>
                <a class="text-zinc-500" href="/edit/<%= val %>" >Edit file name</a>
                <a class="text-zinc-500" href="/delete/<%= val %>">Delete</a>
              </div>
            </div>
            <% }) %>
            <% } else { %>
              <h3 class="text-zinc-600">No tasks yet</h3>
              <% } %>
            </div>
          </div>
          <script src="/javascripts/script.js"></script>
        </body>
        </html>
        