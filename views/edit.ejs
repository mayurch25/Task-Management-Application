<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="main w-full bg-zinc-900 min-h-screen p-10 text-white">
      <a class="text-blue-500 inline-block mb-5 mt-2" href="/">
        Go back to home
      </a>
      <div class="form p-10 mt-2 text-white">
        <form action="/edit" method="post">
          <input
            type="text"
            class="block w-1/4 px-5 py-2 text-zinc-700 bg-zinc-800 w-full rounded-md outline-none"
            placeholder="Previous Name"
            name="previous"
            value="<%= filename %>"
          />
          <input
            type="text"
            class="w-1/4 block px-5 py-2 bg-zinc-800 w-full rounded-md outline-none mt-2"
            placeholder="New Name"
            name="new"
          />
          <input
            class="mt-2 bg-yellow-600 px-5 py-2 rounded-md"
            type="submit"
            value="Update name"
          />
        </form>
    </div>
  </body>
</html>
